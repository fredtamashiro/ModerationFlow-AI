# App
APP_ENV=local
APP_NAME=SmartDocs AI

# Database
DATABASE_URL=postgresql://smartdocs:smartdocs@postgres:5432/smartdocs

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_CHAT_TEMPERATURE=1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Upload / Processing
MAX_UPLOAD_FILE_SIZE_MB=10
CHAT_RATE_LIMIT_PER_IP_DAILY=30
CHAT_RATE_LIMIT_GLOBAL_DAILY=300
MAX_RELEVANCE_SCORE=1.2
MAX_DISPLAY_SOURCE_SCORE=1.0
DISPLAY_SOURCE_SCORE_MARGIN=0.15
MIN_ENRICHED_CHUNK_QUALITY_SCORE=0.5

# Auth / JWT
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# Admin Seed
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=

# Cookies
ADMIN_COOKIE_NAME=smartdocs_admin_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS
FRONTEND_ORIGINS=http://localhost:2000
