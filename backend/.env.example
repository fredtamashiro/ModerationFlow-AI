# App
APP_ENV=development
APP_NAME=ModerationFlow AI
APP_PUBLIC_URL=http://localhost:3003
API_PUBLIC_URL=http://localhost:8000
DEMO_MODE=false

# Database
DATABASE_URL=

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_CHAT_TEMPERATURE=1

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=moderation-flow-ai-dev
# Deixe vazio para usar o endpoint padrao do LangSmith.
LANGSMITH_ENDPOINT=

# Auth / JWT
JWT_SECRET_KEY=change-me-in-development
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# Admin Seed
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Demo Admin

# Demo admin account reference.
# Use only with synthetic seed data and never commit real credentials.
ADMIN_DEMO_EMAIL=
ADMIN_DEMO_PASSWORD=

# Cookies
ADMIN_COOKIE_NAME=moderation_flow_admin_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS
FRONTEND_ORIGINS=http://localhost:3003
