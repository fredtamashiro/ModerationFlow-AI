# App
APP_ENV=local
APP_NAME=ModerationFlow AI

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/moderation_flow

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_CHAT_TEMPERATURE=1

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=moderation-flow-ai-dev
LANGSMITH_ENDPOINT=

# Auth / JWT
JWT_SECRET_KEY=change-me-local
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# Admin Seed
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=admin123
ADMIN_SEED_NAME=Local Admin

# Cookies
ADMIN_COOKIE_NAME=moderation_flow_admin_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS
FRONTEND_ORIGINS=http://localhost:3003
