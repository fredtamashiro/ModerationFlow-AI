# App
APP_ENV=local
APP_NAME=ModerationFlow AI

# Database
DATABASE_URL=postgresql://moderation_flow:moderation_flow@postgres:5432/moderation_flow

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_CHAT_TEMPERATURE=1

# Auth / JWT
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# Admin Seed
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=

# Cookies
ADMIN_COOKIE_NAME=moderation_flow_admin_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS
FRONTEND_ORIGINS=http://localhost:2000
